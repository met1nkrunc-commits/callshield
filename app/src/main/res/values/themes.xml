<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Callshield" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0D1117</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_round</item>
        <item name="windowSplashScreenAnimationDuration">600</item>
        <item name="postSplashScreenTheme">@style/Theme.Callshield.NoSplash</item>
    </style>

    <style name="Theme.Callshield.NoSplash" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">#0D1117</item>
    </style>

</resources>
