<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="callshield.db" />
        <exclude domain="database" path="callshield.db-shm" />
        <exclude domain="database" path="callshield.db-wal" />
        <exclude domain="file"     path="datastore/callshield_prefs.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <!-- User-added blocked numbers transfer between devices -->
        <include domain="database" path="callshield.db" />
    </device-transfer>
</data-extraction-rules>
